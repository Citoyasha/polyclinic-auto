rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    match /customers/{customerId} {
      allow read, write: if isAuth();
    }

    match /cars/{carId} {
      allow read, write: if isAuth();
    }

    match /visits/{visitId} {
      allow read, write: if isAuth();

      match /tasks/{taskId} {
        allow read, write: if isAuth();
      }
      match /lineItems/{itemId} {
        allow read, write: if isAuth();
      }
      match /photos/{photoId} {
        allow read, write: if isAuth();
      }
    }

    match /inventory/{itemId} {
      allow read, write: if isAuth();
    }

    match /inventoryMovements/{movementId} {
      allow read, write: if isAuth();
    }

    // /users mirrors Firebase Auth profiles for the assignee picker.
    // Open to any authenticated user today; tighten to
    // `request.auth.uid == uid` for write when per-user roles arrive.
    match /users/{uid} {
      allow read, write: if isAuth();
    }
  }
}
